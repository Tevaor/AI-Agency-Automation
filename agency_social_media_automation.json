{
  "name": "Agency Social Media Automation Suite",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyX",
              "value": 1,
              "unit": "hours"
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "operation": "read",
        "resource": "sheet",
        "spreadsheetId": "={{$node[\"Google Sheets\"].json[\"id\"]}}",
        "range": "Content!A1:Z1000"
      },
      "name": "Content Calendar",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 2,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "apiKey",
        "operation": "completion",
        "model": "gpt-4",
        "prompt": "Create engaging social media content for {{$json.platform}} based on this topic: {{$json.topic}}. Include relevant hashtags and a call to action. Format: {post: 'main content', hashtags: ['tag1', 'tag2'], cta: 'call to action'}",
        "options": {
          "temperature": 0.7,
          "maxTokens": 500
        }
      },
      "name": "Content Generator",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.platform}}",
              "operation": "equal",
              "value2": "twitter"
            }
          ]
        }
      },
      "name": "Platform Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "oauth2",
        "text": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}",
        "additionalFields": {}
      },
      "name": "Twitter Post",
      "type": "n8n-nodes-base.twitter",
      "typeVersion": 2,
      "position": [
        1050,
        200
      ]
    },
    {
      "parameters": {
        "authentication": "oauth2",
        "text": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}",
        "postAs": "organization",
        "organization": "={{$env.LINKEDIN_ORG_ID}}",
        "additionalFields": {},
        "shareMediaCategory": "IMAGE"
      },
      "name": "LinkedIn Post",
      "type": "n8n-nodes-base.linkedIn",
      "typeVersion": 1,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "authentication": "oauth2",
        "edge": "photos",
        "node": "={{$env.FACEBOOK_PAGE_ID}}",
        "options": {
          "queryParameters": {
            "parameter": [
              {
                "name": "message",
                "value": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}"
              }
            ]
          }
        },
        "sendBinaryData": true,
        "graphApiVersion": "v20.0",
        "httpRequestMethod": "POST",
        "binaryPropertyName": "data"
      },
      "name": "Facebook Post",
      "type": "n8n-nodes-base.facebookGraphApi",
      "typeVersion": 1,
      "position": [
        1050,
        600
      ]
    },
    {
      "parameters": {
        "authentication": "oauth2",
        "operation": "send",
        "to": "={{$env.TEAM_EMAIL}}",
        "subject": "Social Media Post Published",
        "text": "=Post has been published to {{$json.platform}}:\n\n{{$json.post}}\n\nHashtags: {{$json.hashtags.join(', ')}}\n\nCTA: {{$json.cta}}"
      },
      "name": "Notification Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "operation": "append",
        "resource": "sheet",
        "spreadsheetId": "={{$node[\"Google Sheets\"].json[\"id\"]}}",
        "range": "Analytics!A1:Z1000",
        "options": {
          "valueInputMode": "RAW"
        },
        "valueInputMode": "RAW",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "platform": "={{$json.platform}}",
            "post": "={{$json.post}}",
            "hashtags": "={{$json.hashtags.join(', ')}}",
            "cta": "={{$json.cta}}",
            "timestamp": "={{$now.toISOString()}}"
          }
        }
      },
      "name": "Analytics Logger",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 2,
      "position": [
        1450,
        300
      ]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Content Calendar",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Content Calendar": {
      "main": [
        [
          {
            "node": "Content Generator",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Content Generator": {
      "main": [
        [
          {
            "node": "Platform Router",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Platform Router": {
      "main": [
        [
          {
            "node": "Twitter Post",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "LinkedIn Post",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Facebook Post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Twitter Post": {
      "main": [
        [
          {
            "node": "Notification Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "LinkedIn Post": {
      "main": [
        [
          {
            "node": "Notification Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Facebook Post": {
      "main": [
        [
          {
            "node": "Notification Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notification Email": {
      "main": [
        [
          {
            "node": "Analytics Logger",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "versionId": "1.0.0",
  "meta": {
    "instanceId": "agency-social-media-automation"
  },
  "tags": [
    "social-media",
    "automation",
    "content",
    "agency"
  ]
} 