{
  "name": "Test Social Media Automation Suite",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyX",
              "value": 5,
              "unit": "minutes"
            }
          ]
        }
      },
      "name": "Test Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "platform",
              "value": "twitter"
            },
            {
              "name": "topic",
              "value": "AI automation benefits for businesses"
            },
            {
              "name": "scheduled_time",
              "value": "={{$now.toISOString()}}"
            },
            {
              "name": "status",
              "value": "pending"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test Content Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "apiKey",
        "operation": "completion",
        "model": "gpt-4",
        "prompt": "Create engaging social media content for {{$json.platform}} based on this topic: {{$json.topic}}. Include relevant hashtags and a call to action. Format: {post: 'main content', hashtags: ['tag1', 'tag2'], cta: 'call to action'}",
        "options": {
          "temperature": 0.7,
          "maxTokens": 500
        }
      },
      "name": "Test Content Generator",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.platform}}",
              "operation": "equal",
              "value2": "twitter"
            }
          ]
        }
      },
      "name": "Test Platform Router",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "TEST - Would post to Twitter"
            },
            {
              "name": "content",
              "value": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}"
            },
            {
              "name": "timestamp",
              "value": "={{$now.toISOString()}}"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test Twitter Post",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1050,
        200
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "TEST - Would post to LinkedIn"
            },
            {
              "name": "content",
              "value": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}"
            },
            {
              "name": "timestamp",
              "value": "={{$now.toISOString()}}"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test LinkedIn Post",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1050,
        400
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
              "value": "TEST - Would post to Facebook"
            },
            {
              "name": "content",
              "value": "={{$json.post}}\n\n{{$json.hashtags.join(' ')}}\n\n{{$json.cta}}"
            },
            {
              "name": "timestamp",
              "value": "={{$now.toISOString()}}"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test Facebook Post",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1050,
        600
      ]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "notification",
              "value": "=TEST - Would send email notification for {{$json.platform}} post"
            },
            {
              "name": "content_preview",
              "value": "={{$json.post.substring(0, 100)}}..."
            },
            {
              "name": "timestamp",
              "value": "={{$now.toISOString()}}"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test Notification",
      "type": "n8n-nodes-base.set",
