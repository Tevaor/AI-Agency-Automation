            {
              "name": "platform",
              "value": "={{$json.platform}}"
            },
            {
              "name": "post_length",
              "value": "={{$json.post.length}}"
            },
            {
              "name": "hashtag_count",
              "value": "={{$json.hashtags.length}}"
            },
            {
              "name": "timestamp",
              "value": "={{$now.toISOString()}}"
            }
          ]
        },
        "options": {},
        "keepOnlySet": true
      },
      "name": "Test Analytics Logger",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1450,
        300
      ]
    }
